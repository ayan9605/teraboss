# ==========================================
# 🤖 TELEGRAM BOT SETTINGS
# ==========================================

# Your bot token from @BotFather (Required)
TELEGRAM_TOKEN=1234567890:ABCdefGhIJKlmNoPQRstuVWXyz

# Your personal Telegram User ID (Required)
# Must be numbers only! Get this from @userinfobot
ADMIN_ID=123456789

# ID of the channel where downloaded files are dumped (Optional)
# Usually starts with -100 for private channels
DUMP_CHANNEL_ID=-100987654321


# ==========================================
# 💾 DATABASE SETTINGS
# ==========================================

# MongoDB Atlas Connection String (Required if using MongoDB)
# Replace <username> and <password> with your actual database credentials
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority


# ==========================================
# 💳 PAYMENT GATEWAY (UPIMate)
# ==========================================

# Your UPIMate API User Token (Required for auto-payments)
UPIMATE_TOKEN=9c67c53e22e7cae2deeedaeaedce0d24


# ==========================================
# 🌐 SERVER & DEPLOYMENT SETTINGS
# ==========================================

# The port your web server will run on (Default: 5000)
# Render assigns this automatically, but it's good to have it defined
PORT=5000

# Telegram Webhook URL (Leave BLANK for this specific setup!)
# ⚠️ IMPORTANT: If you fill this in, Telegram will block UPIMate from sending payment webhooks.
# Leave it completely empty so the bot uses Polling Mode instead.
WEBHOOK_URL=
